# Scrapyard — environment variable template
# Copy to .env and fill in your values. Never commit .env.

# Jina AI fallback (get a free key at https://jina.ai)
JINA_API_KEY=

# LLM extraction fallback (optional)
# OPENAI_API_KEY=sk-...

# Slack notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Database — required only for --format postgres or mysql
# DATABASE_URL=postgresql://user:password@localhost:5432/scrapyard

# Playwright remote browser (optional)
# PLAYWRIGHT_WS=ws://localhost:3000/playwright
