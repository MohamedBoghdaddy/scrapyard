# Scrapyard v3 – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── AI / LLM ───────────────────────────────────────────────────────────────

# Jina AI Reader API key (used as HTTP fallback after all retries fail)
# Get one at: https://jina.ai
JINA_API_KEY=

# OpenAI API key (used by --llm flag for GPT-4o-mini extraction fallback)
# Get one at: https://platform.openai.com
OPENAI_API_KEY=

# ── Notifications ──────────────────────────────────────────────────────────

# Slack Incoming Webhook URL (for run start/complete/error notifications)
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ── Browserless / Playwright ────────────────────────────────────────────────

# Secret token for the Browserless service (must match docker-compose.yml TOKEN)
BROWSERLESS_TOKEN=scrapyard_secret

# WebSocket URL of the Browserless instance (set automatically in Docker Compose)
# Overrides local Chromium launch in alkhaleeg scraper when set.
PLAYWRIGHT_WS=ws://browserless:3000

# ── Database (optional) ────────────────────────────────────────────────────

# For --format postgres or --format mysql
# PostgreSQL: postgresql://user:password@host:5432/dbname
# MySQL:      mysql://user:password@host:3306/dbname
DATABASE_URL=

# ── Proxy rotation ─────────────────────────────────────────────────────────

# Comma-separated list of HTTP/HTTPS proxy URLs
# Format: http://user:pass@host:port,http://user:pass@host2:port
PROXY_LIST=

# ── PostgreSQL (used by docker-compose.yml) ────────────────────────────────
POSTGRES_USER=scrapyard
POSTGRES_PASSWORD=scrapyard
POSTGRES_DB=scrapyard
